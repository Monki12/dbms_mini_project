# .env.example
# Copy this file to '.env' and populate variables before starting the backend app.

# ----------------------------
# DATABASE CONFIGURATION
# ----------------------------
# Format mapping direct Oracle Easy Connect details or traditional TNS configurations.
DB_USER=clinic_admin
DB_PASSWORD=your_secure_password
DB_DSN=localhost:1521/XEPDB1

# ----------------------------
# JWT AUTHENTICATION
# ----------------------------
# Execute `openssl rand -hex 32` to formulate a secure JWT barrier cryptography key context.
SECRET_KEY=b1d5a7d6e8b4e...
ALGORITHM=HS256

# In minutes (Standard token cycle is 15 -> 60m)
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# In days 
REFRESH_TOKEN_EXPIRE_DAYS=7

# ----------------------------
# SECURITY & CORS
# ----------------------------
# Origins allowed to execute queries onto backend.
# JSON array pattern required for complex list ingestions inside Pydantic.
CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]


OTP_DEV_MODE=true

# ----------------------------
# AI — GEMINI DOCTOR SUGGESTION
# ----------------------------
# Get a key at https://aistudio.google.com/app/apikey
# Leave blank to use the keyword-based fallback instead.
GEMINI_API_KEY=
